# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*~

# Power BI working files — keep the .pbix out of the public repo by default.
# Only commit exported screenshots/images, not source workbooks.
*.pbix
*.pbit

# Source / working data — never publish real or pre-scrubbed datasets.
# (To publish a deliberately scrubbed file, force-add it: git add -f <file>)
assets/source data/
*.xlsx
*.xlsm
*.csv
# ...except the deliberately-scrubbed synthetic data published for the downloadable reports:
!assets/data/
!assets/data/*.xlsx

# Editor folders
.vscode/
.idea/
